{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Integration Workflow",
      "type": "shell",
      "command": "act",
      "args": ["push", "-W", ".github/workflows/integration.yaml"],
      "problemMatcher": [],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Run Deployment Workflow",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/scripts/deploy.sh",
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Sync D1: Production → Local",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/scripts/sync_d1.sh",
      "args": ["local"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Sync D1: Production → Staging",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/scripts/sync_d1.sh",
      "args": ["staging"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Check D1 Schema: Production vs Local",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/scripts/check_d1_schema.sh",
      "args": ["local"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Check D1 Schema: Production vs Staging",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/scripts/check_d1_schema.sh",
      "args": ["staging"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Generate Characters JSON",
      "type": "shell",
      "command": "bun",
      "args": ["${workspaceFolder}/.vscode/scripts/parse_store_info.ts"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Fetch HTML Cache",
      "type": "shell",
      "command": "bun",
      "args": ["${workspaceFolder}/.vscode/scripts/fetch_html.ts"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
