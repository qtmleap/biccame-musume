{
  "extraKnownMarketplaces": {
    "qtmleap-plugins": {
      "source": {
        "source": "github",
        "repo": "qtmleap/claude-plugins"
      }
    }
  },
  "enabledPlugins": {
    "devflow@qtmleap-plugins": true,
    "frontend@qtmleap-plugins": true,
    "backend@qtmleap-plugins": true,
    "data@qtmleap-plugins": true,
    "cloudflare@qtmleap-plugins": true,
    "frontend-design@qtmleap-plugins": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/auto-version-bump.sh"
          }
        ]
      }
    ]
  }
}