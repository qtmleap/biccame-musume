{
  "name": "biccame-musume",
  "version": "0.28.1",
  "type": "module",
  "description": "ビックカメラの店舗擬人化キャラクター「ビッカメ娘」を応援する非公式ファンサイト",
  "author": "@QuantumLeap",
  "private": true,
  "license": "MIT",
  "patchedDependencies": {
    "vite-intlayer@8.5.2": "patches/vite-intlayer@8.5.2.patch"
  },
  "scripts": {
    "dev": "vite --host --port 15175",
    "build": "tsc -b && vite build --mode ${CLOUDFLARE_ENV}",
    "migrate": "wrangler d1 execute biccame-musume-events --env=staging --local --file=./prisma/migrations/init/migration.sql",
    "generate": "prisma generate",
    "prebuild": "rimraf dist && bun run images:download && bun run og:generate",
    "predeploy": "tsc -b && vite build --mode ${CLOUDFLARE_ENV}",
    "deploy": "wrangler deploy --keep-vars --env=${CLOUDFLARE_ENV}",
    "knip": "knip",
    "test:e2e": "playwright test",
    "anniversary:seed": "bun run scripts/seed-anniversary-11.ts",
    "badges:seed": "bun run scripts/seed-badges.ts",
    "badges:backfill": "bun run scripts/backfill-badges.ts",
    "images:download": "bun run scripts/download-character-images.ts",
    "og:generate": "bun run scripts/generate-og-images.ts"
  },
  "dependencies": {
